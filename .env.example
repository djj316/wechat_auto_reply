# ============================================================
# 大模型 API 配置
# ============================================================
# 根据你使用的提供商，设置对应的 API Key。
# 在 config.json 中设置 llm.provider 来选择提供商。
#
# 支持的提供商及对应环境变量:
#   doubao   → DOUBAO_API_KEY    (火山引擎)
#   openai   → OPENAI_API_KEY    (OpenAI)
#   deepseek → DEEPSEEK_API_KEY  (DeepSeek)
#   qwen     → QWEN_API_KEY      (通义千问/阿里云)
#   moonshot → MOONSHOT_API_KEY  (月之暗面/Kimi)
#   glm      → GLM_API_KEY       (智谱)
# ============================================================

# 豆包（火山引擎）
# 获取地址: https://console.volcengine.com/ark
DOUBAO_API_KEY=your_doubao_api_key_here

# OpenAI
# 获取地址: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your_openai_api_key_here

# DeepSeek
# 获取地址: https://platform.deepseek.com/api_keys
# DEEPSEEK_API_KEY=sk-your_deepseek_api_key_here

# 通义千问（阿里云）
# 获取地址: https://help.aliyun.com/zh/model-studio/
# QWEN_API_KEY=sk-your_qwen_api_key_here

# 月之暗面（Kimi）
# 获取地址: https://platform.moonshot.cn/console/api-keys
# MOONSHOT_API_KEY=sk-your_moonshot_api_key_here

# 智谱（GLM）
# 获取地址: https://open.bigmodel.cn/usercenter/apikeys
# GLM_API_KEY=your_glm_api_key_here


# ============================================================
# （可选）自定义 API 端点
# ============================================================
# 如果你需要使用自定义 API 端点（例如代理或私有部署），
# 可以设置对应的环境变量覆盖默认端点。
#
# DOUBAO_API_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3
# OPENAI_API_ENDPOINT=https://api.openai.com/v1
# DEEPSEEK_API_ENDPOINT=https://api.deepseek.com
# QWEN_API_ENDPOINT=https://dashscope.aliyuncs.com/compatible-mode/v1
# MOONSHOT_API_ENDPOINT=https://api.moonshot.cn/v1
# GLM_API_ENDPOINT=https://open.bigmodel.cn/api/paas/v4
